local Library = {}

function Library:CreateWindow(hubName)
    local CoreGui = game:GetService("CoreGui")
    local UserInputService = game:GetService("UserInputService")
    local TweenService = game:GetService("TweenService")
    local RunService = game:GetService("RunService")
    local Players = game:GetService("Players")
    local PlayerGui = Players.LocalPlayer:FindFirstChildOfClass("PlayerGui")
    
    -- ========================================================
    -- 🚨 ANTI-DUPLICATE: XÓA SẠCH TẤT CẢ BẢN SAO TRÙNG LẶP
    -- ========================================================
    local function CleanOldGUIs(parent)
        if parent then
            for _, child in pairs(parent:GetChildren()) do
                if child:IsA("ScreenGui") and (string.find(child.Name, "BacBeo") or string.find(child.Name, "Lybra") or string.find(child.Name, "Dashboard")) then
                    child:Destroy()
                end
            end
        end
    end
    
    CleanOldGUIs(CoreGui)
    CleanOldGUIs(PlayerGui)
    if game:GetService("GuiService") then CleanOldGUIs(game:GetService("GuiService")) end

    local GuiName = "BacBeoHub_Official_Lybra"
    local ScreenGui = Instance.new("ScreenGui", CoreGui)
    ScreenGui.Name = GuiName
    ScreenGui.ResetOnSpawn = false

    -- 1. Khung Main chính gốc
    local MainFrame = Instance.new("Frame", ScreenGui)
    MainFrame.Name = "Main"
    MainFrame.Size = UDim2.new(0, 550, 0, 380)
    MainFrame.Position = UDim2.new(0.5, -275, 0.5, -190)
    MainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    MainFrame.BorderSizePixel = 0
    MainFrame.ClipsDescendants = true 
    MainFrame.Active = true
    MainFrame.Visible = true -- Mặc định ban đầu hiện HUB lớn

    local corner = Instance.new("UICorner", MainFrame)
    corner.CornerRadius = UDim.new(0, 10)

    local UIStroke = Instance.new("UIStroke", MainFrame)
    UIStroke.Color = Color3.fromRGB(0, 255, 100)
    UIStroke.Thickness = 1.5
    UIStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    -- 2. Thanh Tiêu đề (TopBar)
    local TopBar = Instance.new("Frame", MainFrame)
    TopBar.Name = "TopBar"
    TopBar.Size = UDim2.new(1, 0, 0, 50)
    TopBar.BackgroundTransparency = 1

    local title = Instance.new("TextLabel", TopBar)
    title.Size = UDim2.new(0, 250, 1, 0)
    title.Position = UDim2.new(0, 20, 0, 0)
    title.BackgroundTransparency = 1
    title.Text = hubName
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.TextSize = 22
    title.Font = Enum.Font.GothamBold
    title.TextXAlignment = Enum.TextXAlignment.Left

    -- Nút tam giác thu gọn kích thước khung
    local ToggleBtn = Instance.new("TextButton", TopBar)
    ToggleBtn.Name = "ToggleBtn"
    ToggleBtn.Size = UDim2.new(0, 35, 0, 35)
    ToggleBtn.Position = UDim2.new(1, -45, 0, 7) 
    ToggleBtn.BackgroundTransparency = 1
    ToggleBtn.Text = "▼"
    ToggleBtn.TextColor3 = Color3.fromRGB(0, 255, 100)
    ToggleBtn.TextSize = 20
    ToggleBtn.Font = Enum.Font.SourceSansBold

    -- 3. Khung bên trái và Khung bên phải
    local leftContainer = Instance.new("Frame", MainFrame)
    leftContainer.Name = "LeftContainer"
    leftContainer.Size = UDim2.new(0, 150, 1, -65)
    leftContainer.Position = UDim2.new(0, 10, 0, 55)
    leftContainer.BackgroundTransparency = 1

    local leftLayout = Instance.new("UIListLayout", leftContainer)
    leftLayout.SortOrder = Enum.SortOrder.LayoutOrder
    leftLayout.Padding = UDim.new(0, 8)

    local rightContainer = Instance.new("ScrollingFrame", MainFrame)
    rightContainer.Name = "RightContainer"
    rightContainer.Size = UDim2.new(1, -180, 1, -65)
    rightContainer.Position = UDim2.new(0, 170, 0, 55)
    rightContainer.BackgroundTransparency = 1
    rightContainer.CanvasSize = UDim2.new(0, 0, 0, 0)
    rightContainer.AutomaticCanvasSize = Enum.AutomaticSize.Y
    rightContainer.ScrollBarThickness = 3
    rightContainer.ScrollBarImageColor3 = Color3.fromRGB(0, 255, 100)

    local rightLayout = Instance.new("UIListLayout", rightContainer)
    rightLayout.SortOrder = Enum.SortOrder.LayoutOrder
    rightLayout.Padding = UDim.new(0, 8)

    -- LOGIC CLICK NÚT TAM GIÁC THU GỌN KHUNG
    local IsCollapsed = false
    local OriginalSize = UDim2.new(0, 550, 0, 380)
    local CollapsedSize = UDim2.new(0, 550, 0, 50) 

    ToggleBtn.MouseButton1Click:Connect(function()
        IsCollapsed = not IsCollapsed
        if IsCollapsed then
            ToggleBtn.Text = "▲"
            leftContainer.Visible = false
            rightContainer.Visible = false
            TweenService:Create(MainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = CollapsedSize}):Play()
        else
            ToggleBtn.Text = "▼"
            local tween = TweenService:Create(MainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = OriginalSize})
            tween:Play()
            tween.Completed:Connect(function()
                if not IsCollapsed then
                    leftContainer.Visible = true
                    rightContainer.Visible = true
                end
            end)
        end
    end)

    -- ========================================================
    -- 📱 HỆ THỐNG KÉO THẢ MAIN FRAME
    -- ========================================================
    local dragging = false
    local dragInput, dragStart, startPos

    local function updateDrag(input)
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(
            startPos.X.Scale, 
            startPos.X.Offset + delta.X, 
            startPos.Y.Scale, 
            startPos.Y.Offset + delta.Y
        )
    end

    TopBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)

    TopBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then updateDrag(input) end
    end)

    -- ========================================================
    -- 🔘 HỆ THỐNG NÚT MINI LOGO TRÒN (VIỀN CẦU VỒNG + GÓC PHẢI)
    -- ========================================================
    local isOpened = true

    local MiniLogo = Instance.new("ImageButton")
    MiniLogo.Name = "BacBeo_MiniLogo"
    MiniLogo.Parent = ScreenGui
    MiniLogo.Size = UDim2.new(0, 50, 0, 50)
    -- 📍 Đổi vị trí xuất hiện đầu tiên sang góc RÌA BÊN PHẢI màn hình (Scale X = 0.95 để lùi vào một chút không bị tràn)
    MiniLogo.Position = UDim2.new(0.95, -25, 0.5, -25) 
    MiniLogo.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    MiniLogo.Image = "rbxassetid://100698867542221"
    MiniLogo.Visible = false -- Ban đầu ẩn đi vì HUB đang hiện
    MiniLogo.ZIndex = 100000
    MiniLogo.Active = true

    local LogoText = Instance.new("TextLabel", MiniLogo)
    LogoText.Name = "LogoText"
    LogoText.Size = UDim2.new(1, 0, 1, 0)
    LogoText.BackgroundTransparency = 1
    LogoText.Text = "BB"
    LogoText.TextColor3 = Color3.fromRGB(0, 255, 100)
    LogoText.TextSize = 18
    LogoText.Font = Enum.Font.GothamBold
    LogoText.ZIndex = 100001

    MiniLogo:GetPropertyChangedSignal("Image"):Connect(function()
        if MiniLogo.Image ~= "" then LogoText.Visible = false else LogoText.Visible = true end
    end)
    if MiniLogo.Image ~= "" then LogoText.Visible = false end

    Instance.new("UICorner", MiniLogo).CornerRadius = UDim.new(1, 0)
    local stroke = Instance.new("UIStroke", MiniLogo)
    stroke.Thickness = 2
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    -- 🌈 HIỆU ỨNG VIỀN CẦU VỒNG (RAINBOW RGB)
    RunService.RenderStepped:Connect(function()
        local hue = (tick() % 3) / 3 -- Thay đổi số 3 thành số lớn hơn nếu muốn màu đổi chậm lại
        stroke.Color = Color3.fromHSV(hue, 1, 1)
    end)

    -- Hàm xử lý trạng thái Đóng/Mở đồng bộ
    local function ToggleMainUI(state)
        isOpened = state
        MainFrame.Visible = isOpened
        MiniLogo.Visible = not isOpened
    end

    -- HỆ THỐNG KÉO THẢ NÚT TRÒN KHÔNG BỊ TRÙNG CLICK MỞ HUB
    local logoDragging = false
    local logoDragStart, logoStartPos
    local mouseStartPos = Vector3.new(0, 0, 0)

    MiniLogo.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            logoDragging = true
            logoDragStart = input.Position
            logoStartPos = MiniLogo.Position
            mouseStartPos = input.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then 
                    logoDragging = false 
                end
            end)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if logoDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - logoDragStart
            MiniLogo.Position = UDim2.new(logoStartPos.X.Scale, logoStartPos.X.Offset + delta.X, logoStartPos.Y.Scale, logoStartPos.Y.Offset + delta.Y)
        end
    end)

    MiniLogo.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            logoDragging = false
            local mouseDelta = (input.Position - mouseStartPos).Magnitude
            
            -- Nếu thả chuột lệch không quá 5 pixel -> Click tại chỗ -> Mở HUB lớn
            if mouseDelta <= 5 then
                ToggleMainUI(true)
            end
        end
    end)

    -- ========================================================
    -- ⌨️ TỔ HỢP PHÍM BÍ MẬT "H-U-B" (CÓ KHÓA KHI ĐANG ẨN)
    -- ========================================================
    local keySequence = {}
    local targetSequence = {"H", "U", "B"}
    local lastKeyTime = 0

    UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end 
        
        -- 🔒 KHÓA PHÍM: Nếu HUB lớn đang đóng (isOpened == false), chặn đứng hoàn toàn không cho dùng H-U-B
        if not isOpened then return end

        if input.UserInputType == Enum.UserInputType.Keyboard then
            local keyName = input.KeyCode.Name
            local currentTime = tick()
            
            if currentTime - lastKeyTime > 1.0 then
                keySequence = {}
            end
            lastKeyTime = currentTime
            
            table.insert(keySequence, keyName)
            if #keySequence > 3 then table.remove(keySequence, 1) end
            
            if keySequence[1] == targetSequence[1] and
