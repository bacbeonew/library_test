local Library = {}

function Library:CreateWindow(hubName)
    local CoreGui = game:GetService("CoreGui")
    local UserInputService = game:GetService("UserInputService")
    local TweenService = game:GetService("TweenService")
    local Players = game:GetService("Players")
    
    local GuiName = "BacBeoDashboardPro"
    local ScreenGui = CoreGui:FindFirstChild(GuiName)
    
    -- Nếu đã có ScreenGui cũ thì gom chung, chưa có thì tạo mới
    if not ScreenGui then
        ScreenGui = Instance.new("ScreenGui", CoreGui)
        ScreenGui.Name = GuiName
        ScreenGui.ResetOnSpawn = false
    end

    -- TÍNH NĂNG: Bắt tất cả các Hub cũ thu nhỏ lại thành thanh tiêu đề
    for _, child in pairs(ScreenGui:GetChildren()) do
        if child:IsA("Frame") and child.Name == "MainFrame" then
            if child:FindFirstChild("ScrollingFrame") then child.ScrollingFrame.Visible = false end
            if child:FindFirstChild("ImageLabel") then child.ImageLabel.Visible = false end
            for _, txt in pairs(child:GetChildren()) do
                if txt:IsA("TextLabel") and txt.Name ~= "Title" then txt.Visible = false end
            end
            if child:FindFirstChild("ToggleBtn") then child.ToggleBtn.Text = "▲" end
            child.Size = UDim2.new(0, 420, 0, 45)
        end
    end

    -- 1. Khung Main chính
    local MainFrame = Instance.new("Frame", ScreenGui)
    MainFrame.Name = "MainFrame"
    MainFrame.Size = UDim2.new(0, 420, 0, 320)
    
    -- Dịch chuyển tọa độ nhẹ để không đè khít lên cái cũ
    local existingHubs = 0
    for _, child in pairs(ScreenGui:GetChildren()) do if child.Name == "MainFrame" then existingHubs = existingHubs + 1 end end
    MainFrame.Position = UDim2.new(0.5, -210 + ((existingHubs - 1) * 15), 0.5, -160 + ((existingHubs - 1) * 15))
    
    MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    MainFrame.ClipsDescendants = true
    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 12)

    -- Viền phát sáng Neon màu xanh hacker
    local UIStroke = Instance.new("UIStroke", MainFrame)
    UIStroke.Color = Color3.fromRGB(0, 255, 100)
    UIStroke.Thickness = 2
    UIStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    -- 2. Tiêu đề
    local Title = Instance.new("TextLabel", MainFrame)
    Title.Name = "Title"
    Title.Size = UDim2.new(1, 0, 0, 45)
    Title.Text = "    " .. hubName
    Title.TextColor3 = Color3.fromRGB(0, 255, 100)
    Title.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    Title.Font = Enum.Font.Code
    Title.TextSize = 18
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Instance.new("UICorner", Title).CornerRadius = UDim.new(0, 12)

    -- Tự động lấy Avatar người dùng
    local AvatarImg = Instance.new("ImageLabel", MainFrame)
    AvatarImg.Size = UDim2.new(0, 50, 0, 50)
    AvatarImg.Position = UDim2.new(0, 15, 0, 60)
    AvatarImg.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Instance.new("UICorner", AvatarImg).CornerRadius = UDim.new(1, 0)
    
    local UserStroke = Instance.new("UIStroke", AvatarImg)
    UserStroke.Color = Color3.fromRGB(0, 255, 100)
    UserStroke.Thickness = 1.5

    task.spawn(function()
        local success, content = pcall(function()
            return Players:GetUserThumbnailAsync(Players.LocalPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
        end)
        if success then AvatarImg.Image = content end
    end)

    local WelcomeText = Instance.new("TextLabel", MainFrame)
    WelcomeText.Size = UDim2.new(0, 200, 0, 20)
    WelcomeText.Position = UDim2.new(0, 75, 0, 75)
    WelcomeText.Text = "Chào chủ nhân: " .. Players.LocalPlayer.Name
    WelcomeText.Font = Enum.Font.Code
    WelcomeText.TextColor3 = Color3.fromRGB(255, 255, 255)
    WelcomeText.TextSize = 14
    WelcomeText.BackgroundTransparency = 1
    WelcomeText.TextXAlignment = Enum.TextXAlignment.Left

    -- 3. Khung chứa Folder nút bấm
    local Container = Instance.new("ScrollingFrame", MainFrame)
    Container.Size = UDim2.new(1, -30, 1, -135)
    Container.Position = UDim2.new(0, 15, 0, 125)
    Container.BackgroundTransparency = 1
    Container.ScrollBarThickness = 3
    Container.ScrollBarImageColor3 = Color3.fromRGB(0, 255, 100)
    Container.AutomaticCanvasSize = Enum.AutomaticSize.Y
    local Layout = Instance.new("UIListLayout", Container)
    Layout.Padding = UDim.new(0, 8)

    -- Nút tam giác ẩn/hiện menu
    local ToggleBtn = Instance.new("TextButton", MainFrame)
    ToggleBtn.Name = "ToggleBtn"
    ToggleBtn.Size = UDim2.new(0, 30, 0, 30)
    ToggleBtn.Position = UDim2.new(1, -35, 0, 7)
    ToggleBtn.BackgroundTransparency = 1
    ToggleBtn.Text = "▼"
    ToggleBtn.TextColor3 = Color3.fromRGB(0, 255, 100)
    ToggleBtn.TextSize = 18
    ToggleBtn.Font = Enum.Font.SourceSansBold
    ToggleBtn.ZIndex = 10

    local IsCollapsed = false
    ToggleBtn.MouseButton1Click:Connect(function()
        IsCollapsed = not IsCollapsed
        if IsCollapsed then
            Container.Visible = false; AvatarImg.Visible = false; WelcomeText.Visible = false; ToggleBtn.Text = "▲"
            MainFrame.Size = UDim2.new(0, 420, 0, 45)
        else
            Container.Visible = true; AvatarImg.Visible = true; WelcomeText.Visible = true; ToggleBtn.Text = "▼"
            MainFrame.Size = UDim2.new(0, 420, 0, 320)
        end
    end)

    -- Bảng thông tin Game ID
    local InfoFrame = ScreenGui:FindFirstChild("InfoFrame")
    if not InfoFrame then
        InfoFrame = Instance.new("Frame", ScreenGui)
        InfoFrame.Name = "InfoFrame"
        InfoFrame.Size = UDim2.new(0, 190, 0, 45)
        InfoFrame.Position = UDim2.new(1, -205, 0, 15)
        InfoFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
        InfoFrame.BackgroundTransparency = 0.4
        Instance.new("UICorner", InfoFrame)
        local InfoStroke = Instance.new("UIStroke", InfoFrame)
        InfoStroke.Color = Color3.fromRGB(0, 255, 100)
        InfoStroke.Thickness = 1

        local InfoText = Instance.new("TextLabel", InfoFrame)
        InfoText.Size = UDim2.new(1, -10, 1, -10)
        InfoText.Position = UDim2.new(0, 5, 0, 5)
        InfoText.Font = Enum.Font.Code
        InfoText.TextColor3 = Color3.fromRGB(0, 255, 100)
        InfoText.TextSize = 13
        InfoText.BackgroundTransparency = 1
        InfoText.Text = "Game ID: " .. game.PlaceId
    end

    -- KÉO THẢ
    local dragging, dragStart, startPos
    MainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = MainFrame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)

    -- Phím tắt RightControl
    local isOpened = true
    UserInputService.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == Enum.KeyCode.RightControl then
            isOpened = not isOpened
            local targetSize = isOpened and UDim2.new(0, 420, 0, 320) or UDim2.new(0, 420, 0, 0)
            TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = targetSize}):Play()
            if not isOpened then
                Container.Visible = false; AvatarImg.Visible = false; WelcomeText.Visible = false; ToggleBtn.Text = "▲"
                IsCollapsed = true
            else
                Container.Visible = true; AvatarImg.Visible = true; WelcomeText.Visible = true; ToggleBtn.Text = "▼"
                IsCollapsed = false
            end
        end
    end)

    -- LOGIC TẠO FOLDER VÀ CÁC THÀNH PHẦN CON
    local WindowActions = {}
    
    function WindowActions:CreateFolder(folderName)
        local Folder = Instance.new("Frame", Container)
        Folder.Size = UDim2.new(1, 0, 0, 25)
        Folder.AutomaticSize = Enum.AutomaticSize.Y
        Folder.BackgroundTransparency = 1
        
        local FolderLayout = Instance.new("UIListLayout", Folder)
        FolderLayout.Padding = UDim.new(0, 6)

        local FolderTitle = Instance.new("TextLabel", Folder)
        FolderTitle.Size = UDim2.new(1, 0, 0, 20)
        FolderTitle.Text = "[" .. folderName:upper() .. "]"
        FolderTitle.TextColor3 = Color3.fromRGB(150, 150, 150)
        FolderTitle.Font = Enum.Font.Code
        FolderTitle.TextSize = 14
        FolderTitle.BackgroundTransparency = 1
        FolderTitle.TextXAlignment = Enum.TextXAlignment.Left

        local FolderActions = {}
        
        -- 1. Hàm tạo Button (Chấp nhận cả :CreateButton và :Button)
        function FolderActions:CreateButton(btnName, callback)
            local Button = Instance.new("TextButton", Folder)
            Button.Size = UDim2.new(1, 0, 0, 36)
            Button.Text = btnName
            Button.Font = Enum.Font.Code
            Button.TextSize = 14
            Button.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            Button.TextColor3 = Color3.new(1, 1, 1)
            Instance.new("UICorner", Button).CornerRadius = UDim.new(0, 6)
            
            local BtnStroke = Instance.new("UIStroke", Button)
            BtnStroke.Color = Color3.fromRGB(50, 50, 50)
            
            Button.MouseEnter:Connect(function() BtnStroke.Color = Color3.fromRGB(0, 255, 100) end)
            Button.MouseLeave:Connect(function() BtnStroke.Color = Color3.fromRGB(50, 50, 50) end)
            Button.MouseButton1Click:Connect(callback)
        end
        FolderActions.Button = FolderActions.CreateButton

        -- 2. Hàm tạo Toggle chuẩn chỉ
        function FolderActions:Toggle(toggleName, callback)
            local ToggleFrame = Instance.new("Frame", Folder)
            ToggleFrame.Size = UDim2.new(1, 0, 0, 36)
            ToggleFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            Instance.new("UICorner", ToggleFrame).CornerRadius = UDim.new(0, 6)
            
            local TStroke = Instance.new("UIStroke", ToggleFrame)
            TStroke.Color = Color3.fromRGB(50, 50, 50)

            local ToggleLabel = Instance.new("TextLabel", ToggleFrame)
            ToggleLabel.Size = UDim2.new(1, -50, 1, 0)
            ToggleLabel.Position = UDim2.new(0, 10, 0, 0)
            ToggleLabel.Text = toggleName
            ToggleLabel.Font = Enum.Font.Code
            ToggleLabel.TextSize = 14
            ToggleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            ToggleLabel.TextXAlignment = Enum.TextXAlignment.Left
            ToggleLabel.BackgroundTransparency = 1

            local CheckBox = Instance.new("TextButton", ToggleFrame)
            CheckBox.Size = UDim2.new(0, 20, 0, 20)
            CheckBox.Position = UDim2.new(1, -30, 0.5, -10)
            CheckBox.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
            CheckBox.Text = ""
            Instance.new("UICorner", CheckBox).CornerRadius = UDim.new(0, 4)
            
            local CBStroke = Instance.new("UIStroke", CheckBox)
            CBStroke.Color = Color3.fromRGB(80, 80, 80)

            local state = false
            CheckBox.MouseButton1Click:Connect(function()
                state = not state
                if state then
                    CheckBox.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
                    CheckBox.Text = "✓"
                    CheckBox.TextColor3 = Color3.fromRGB(0, 0, 0)
                    TStroke.Color = Color3.fromRGB(0, 255, 100)
                else
