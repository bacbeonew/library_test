-- ĐÂY LÀ ĐOẠN CODE CẦN SỬA BÊN TRONG FILE LIBRA CỦA ÔNG
function library:CreateFolder(folderName)
    local FolderFrame = Instance.new("Frame")
    FolderFrame.Name = folderName .. "_Folder"
    FolderFrame.Size = UDim2.new(1, 0, 0, 30) -- Mặc định ban đầu thu gọn (chỉ vừa chiều cao chữ)
    FolderFrame.BackgroundTransparency = 1
    FolderFrame.ClipsDescendants = true -- Bắt buộc phải có để giấu nút con khi thu nhỏ
    FolderFrame.Parent = MainScrollFrame -- Hoặc cái khung chứa chính trong UI của bạn

    -- Chuyển chữ xám thành TextButton để bấm được
    local FolderTitle = Instance.new("TextButton")
    FolderTitle.Size = UDim2.new(1, 0, 0, 30)
    FolderTitle.BackgroundTransparency = 1
    FolderTitle.Text = "[" .. folderName:upper() .. "]"
    FolderTitle.TextColor3 = Color3.fromRGB(150, 150, 150)
    FolderTitle.TextXAlignment = Enum.TextXAlignment.Left
    FolderTitle.Font = Enum.Font.SourceSansBold
    FolderTitle.TextSize = 18
    FolderTitle.Parent = FolderFrame

    -- Khung chứa các nút con thực sự
    local Container = Instance.new("Frame")
    Container.Name = "Container"
    Container.Size = UDim2.new(1, 0, 0, 0)
    Container.Position = UDim2.new(0, 0, 0, 35)
    Container.BackgroundTransparency = 1
    Container.Parent = FolderFrame

    local ListLayout = Instance.new("UIListLayout")
    ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    ListLayout.Padding = UDim.new(0, 5)
    ListLayout.Parent = Container

    -- Logic bấm vào chữ xám để xổ menu xuống mượt mà
    local isOpened = false
    FolderTitle.MouseButton1Click:Connect(function()
        isOpened = not isOpened
        local targetHeight = isOpened and ListLayout.AbsoluteContentSize.Y or 0
        
        local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        game:GetService("TweenService"):Create(Container, tweenInfo, {Size = UDim2.new(1, 0, 0, targetHeight)}):Play()
        game:GetService("TweenService"):Create(FolderFrame, tweenInfo, {Size = UDim2.new(1, 0, 0, targetHeight + 40)}):Play()
        
        FolderTitle.TextColor3 = isOpened and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(150, 150, 150)
    end)

    -- Trả về một bảng chứa các hàm tạo nút, nhưng mục tiêu ép vào 'Container' thay vì FolderFrame cũ
    local elements = {}
    
    function elements:Button(text, callback)
        -- Code tạo Button của libra cũ...
        -- Nhưng thay vì đặt Parent = FolderFrame, hãy sửa thành Parent = Container
    end
    
    function elements:Toggle(text, callback)
        -- Code tạo Toggle của libra cũ...
        -- Thay vì đặt Parent = FolderFrame, hãy sửa thành Parent = Container
    end

    function elements:Box(text, datatype, callback)
        -- Code tạo Box của libra cũ...
        -- Thay vì đặt Parent = FolderFrame, hãy sửa thành Parent = Container
    end

    return elements
end
